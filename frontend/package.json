{
  "name": "frontend",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint --cache --fix .",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:cucumber": "node --import tsx node_modules/@cucumber/cucumber/bin/cucumber.js --config ./cucumber.mjs",
    "test:bdd": "npm run test:cucumber",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "playwright test --grep='@smoke'",
    "test:performance": "playwright test tests/performance/",
    "test:visual": "playwright test tests/visual/",
    "test:lighthouse": "lhci autorun",
    "test:all": "npm run test:unit && npm run test && npm run test:cucumber",
    "test:ci:smoke": "npm run test:unit && npm run test:smoke",
    "test:ci:full": "npm run test:unit && npm run test && npm run test:cucumber && npm run test:performance"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "ky": "^1.14.3",
    "svelte-virtual-list": "^3.0.1",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.5.2",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.45.0",
    "globals": "^15.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.13.4",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "svelte-eslint-parser": "^0.43.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.11",
    "vitest": "^3.0.0"
  }
}
