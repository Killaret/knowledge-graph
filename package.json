{
  "name": "knowledge-graph",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "cd frontend && npm run lint",
    "lint:backend": "cd backend && golangci-lint run",
    "format": "cd frontend && npm run format",
    "test": "cd frontend && npm run test:unit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.0.0",
    "tsx": "^4.21.0"
  },
  "lint-staged": {
    "frontend/**/*.{svelte,ts,js}": [
      "cd frontend && npm run lint",
      "cd frontend && npm run format"
    ],
    "backend/**/*.go": [
      "cd backend && golangci-lint run --new-from-rev=HEAD~1"
    ]
  }
}
